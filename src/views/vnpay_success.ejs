<!DOCTYPE html>
<html lang="vi">
<head>
  <meta charset="UTF-8">
  <title>Kết quả thanh toán</title>
</head>
<body>
  <% if (code === '00') { %>
    <h2>🎉 Thanh toán thành công!</h2>
  <% } else { %>
    <h2>❌ Thanh toán thất bại. Mã lỗi: <%= code %></h2>
  <% } %>
  <a href="/">Quay lại trang chủ</a>
</body>
</html>
